<UserControl x:Class="FullVid.Dialogs.VideoPlayerDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             mc:Ignorable="d"
             d:DesignHeight="720" d:DesignWidth="1280"
             Focusable="True">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <materialDesign:BundledTheme BaseTheme="Dark" PrimaryColor="DeepPurple" SecondaryColor="Lime" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.Defaults.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <!-- Single-cell grid: the glass hint bar floats OVER the bottom of the video. WPF can't
         blur the WebView2 content behind it (separate airspace HWND), so the frosted look is a
         translucent dark panel with a top highlight line + drop shadow — reads as glass on the
         video without needing a real backdrop blur. -->
    <Grid Background="#212121">
        <wv2:WebView2 x:Name="Web" DefaultBackgroundColor="Black"/>

        <Border VerticalAlignment="Bottom"
                Background="#B0141414"
                BorderBrush="#33FFFFFF"
                BorderThickness="0,1,0,0"
                Padding="0,11,0,11">
            <Border.Effect>
                <DropShadowEffect Color="Black" BlurRadius="24" ShadowDepth="0" Opacity="0.55"/>
            </Border.Effect>
            <TextBlock FontSize="14"
                       TextAlignment="Center"
                       TextWrapping="Wrap">
                <Run Text="A / Space" Foreground="#B39DDB" FontWeight="Bold"/><Run Text=" Play/Pause" Foreground="#F5F5F5"/>
                <Run Text="   •   " Foreground="#66FFFFFF"/>
                <Run Text="◄ ►" Foreground="#B39DDB" FontWeight="Bold"/><Run Text=" Seek 10s" Foreground="#F5F5F5"/>
                <Run Text="   •   " Foreground="#66FFFFFF"/>
                <Run Text="▲ ▼" Foreground="#B39DDB" FontWeight="Bold"/><Run Text=" Volume" Foreground="#F5F5F5"/>
                <Run Text="   •   " Foreground="#66FFFFFF"/>
                <Run Text="Y / D" Foreground="#B39DDB" FontWeight="Bold"/><Run Text=" Download" Foreground="#F5F5F5"/>
                <Run Text="   •   " Foreground="#66FFFFFF"/>
                <Run Text="B / Esc" Foreground="#EF9A9A" FontWeight="Bold"/><Run Text=" Close" Foreground="#F5F5F5"/>
            </TextBlock>
        </Border>
    </Grid>
</UserControl>
