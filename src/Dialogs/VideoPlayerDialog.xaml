<UserControl x:Class="FullVid.Dialogs.VideoPlayerDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             mc:Ignorable="d"
             d:DesignHeight="720" d:DesignWidth="1280"
             Focusable="True">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <materialDesign:BundledTheme BaseTheme="Dark" PrimaryColor="DeepPurple" SecondaryColor="Lime" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.Defaults.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <!-- WebView2CompositionControl composes into the WPF visual tree, so we can render over the
         video. The hint bar is real frosted glass: a live VisualBrush of the video's bottom strip
         is blurred behind the text, so you see the (blurred) video through the bar instead of an
         opaque block. The brush samples only the bottom band of the video (Viewbox), so it's cheap
         — one small blurred region, not the whole frame. Requires WebView2 runtime 132+. -->
    <Grid Background="#212121">
        <wv2:WebView2CompositionControl x:Name="Web" DefaultBackgroundColor="Black"/>

        <Grid x:Name="HintBar" VerticalAlignment="Bottom" Height="48">
            <!-- Frosted backing: blurred live slice of the video behind the bar. Viewbox maps to
                 the bottom ~7% of the source so the brush samples just this strip's worth of video.
                 LowQuality scaling + the blur mean the sampled region can be coarse and cheap. -->
            <Rectangle RenderOptions.BitmapScalingMode="LowQuality">
                <Rectangle.Fill>
                    <VisualBrush Visual="{Binding ElementName=Web}"
                                 Stretch="Fill"
                                 ViewboxUnits="RelativeToBoundingBox"
                                 Viewbox="0,0.93,1,0.07"/>
                </Rectangle.Fill>
                <Rectangle.Effect>
                    <BlurEffect Radius="30" KernelType="Gaussian" RenderingBias="Performance"/>
                </Rectangle.Effect>
            </Rectangle>

            <!-- Dark glass tint + top highlight so text stays legible over any video. -->
            <Border Background="#59151515" BorderBrush="#40FFFFFF" BorderThickness="0,1,0,0"/>

            <TextBlock VerticalAlignment="Center"
                       FontSize="14"
                       TextAlignment="Center"
                       TextWrapping="Wrap">
                <Run Text="A / Space" Foreground="#B39DDB" FontWeight="Bold"/><Run Text=" Play/Pause" Foreground="#F5F5F5"/>
                <Run Text="   •   " Foreground="#66FFFFFF"/>
                <Run Text="◄ ►" Foreground="#B39DDB" FontWeight="Bold"/><Run Text=" Seek 10s" Foreground="#F5F5F5"/>
                <Run Text="   •   " Foreground="#66FFFFFF"/>
                <Run Text="▲ ▼" Foreground="#B39DDB" FontWeight="Bold"/><Run Text=" Volume" Foreground="#F5F5F5"/>
                <Run Text="   •   " Foreground="#66FFFFFF"/>
                <Run Text="Y / D" Foreground="#B39DDB" FontWeight="Bold"/><Run Text=" Download" Foreground="#F5F5F5"/>
                <Run Text="   •   " Foreground="#66FFFFFF"/>
                <Run Text="B / Esc" Foreground="#EF9A9A" FontWeight="Bold"/><Run Text=" Close" Foreground="#F5F5F5"/>
            </TextBlock>
        </Grid>
    </Grid>
</UserControl>
