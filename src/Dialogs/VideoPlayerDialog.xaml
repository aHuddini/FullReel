<UserControl x:Class="FullVid.Dialogs.VideoPlayerDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             mc:Ignorable="d"
             d:DesignHeight="720" d:DesignWidth="1280"
             Focusable="True">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <materialDesign:BundledTheme BaseTheme="Dark" PrimaryColor="DeepPurple" SecondaryColor="Lime" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.Defaults.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Shared controls legend. x:Shared=False so the same markup can back both bar
                 styles (a FrameworkElement can't have two parents). -->
            <TextBlock x:Key="HintText" x:Shared="False"
                       FontSize="14" TextAlignment="Center" TextWrapping="Wrap">
                <Run Text="A / Space" Foreground="#B39DDB" FontWeight="Bold"/><Run Text=" Play/Pause" Foreground="#F5F5F5"/>
                <Run Text="   •   " Foreground="#66FFFFFF"/>
                <Run Text="◄ ►" Foreground="#B39DDB" FontWeight="Bold"/><Run Text=" Seek 10s" Foreground="#F5F5F5"/>
                <Run Text="   •   " Foreground="#66FFFFFF"/>
                <Run Text="▲ ▼" Foreground="#B39DDB" FontWeight="Bold"/><Run Text=" Volume" Foreground="#F5F5F5"/>
                <Run Text="   •   " Foreground="#66FFFFFF"/>
                <Run Text="Y / D" Foreground="#B39DDB" FontWeight="Bold"/><Run Text=" Download" Foreground="#F5F5F5"/>
                <Run Text="   •   " Foreground="#66FFFFFF"/>
                <Run Text="B / Esc" Foreground="#EF9A9A" FontWeight="Bold"/><Run Text=" Close" Foreground="#F5F5F5"/>
            </TextBlock>
        </ResourceDictionary>
    </UserControl.Resources>

    <!-- Two hint-bar styles, chosen by the PlayerBarStyle setting (code-behind toggles them):
         • FrostedBlur: the bar is an HTML overlay INSIDE the WebView2 page (see BuildPlayerHtml)
           using CSS backdrop-filter — Chromium blurs its own video on the GPU. No WPF bar, no
           snapshots, zero WPF-side cost.
         • Performance: plain translucent WPF strip BELOW the video — no blur, no overlay. -->
    <!-- Black backing (not #212121): the WebView2 HwndHost can round a sub-pixel short of the
         window's bottom edge (visible on zoom / at 200% scaling), and a gray backing showed
         through that gap as a light seam riding the window edge — mistaken for a page artifact.
         Black makes any residual gap invisible. Pairs with the WebView2 bottom overhang in code-behind. -->
    <Grid Background="#000000">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>                        <!-- Player -->
            <RowDefinition x:Name="PerfBarRow" Height="Auto"/>  <!-- Performance strip (collapsed in frosted mode) -->
        </Grid.RowDefinitions>

        <!-- Plain WebView2 (HwndHost), NOT the composition control: it renders video directly with
             no per-frame Windows.Graphics.Capture → D3DImage copy, so playback is smooth. We don't
             need composition anymore — the glass bars are in-page HTML (no WPF-over-webview
             airspace), and the Performance strip sits in its own row below the video (no overlap). -->
        <wv2:WebView2 Grid.Row="0" x:Name="Web" DefaultBackgroundColor="Black"/>

        <!-- PERFORMANCE: plain strip in its own row below the video. Hidden in frosted mode. -->
        <Border x:Name="PerfBar" Grid.Row="1"
                Background="#5C1A1A1A" BorderBrush="#33FFFFFF" BorderThickness="0,1,0,0"
                Padding="0,11,0,11" Visibility="Collapsed">
            <ContentControl Content="{StaticResource HintText}"/>
        </Border>
    </Grid>
</UserControl>
