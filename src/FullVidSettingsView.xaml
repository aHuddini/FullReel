<UserControl x:Class="FullVid.FullVidSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:local="clr-namespace:FullVid"
             mc:Ignorable="d"
             d:DesignHeight="520" d:DesignWidth="640">
    <UserControl.Resources>
        <ObjectDataProvider x:Key="VideoQualityValues" MethodName="GetValues" ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="local:VideoQuality"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
        <ObjectDataProvider x:Key="CookieModeValues" MethodName="GetValues" ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="local:CookieMode"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
        <ObjectDataProvider x:Key="PlayerBarStyleValues" MethodName="GetValues" ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="local:PlayerBarStyle"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">
            <TextBlock Text="Download Tools" FontSize="18" FontWeight="Bold" Margin="0,0,0,4"/>
            <TextBlock Text="FullReel uses yt-dlp to fetch videos and ffmpeg to process them. Point each to its .exe."
                       FontSize="11" Foreground="Gray" TextWrapping="Wrap" Margin="0,0,0,14"/>

            <!-- yt-dlp -->
            <StackPanel Orientation="Horizontal" Margin="0,5">
                <TextBlock Text="yt-dlp Path:" VerticalAlignment="Center" Width="110"/>
                <TextBox Text="{Binding Settings.YtDlpPath, UpdateSourceTrigger=PropertyChanged}" Width="320" Margin="0,0,10,0"/>
                <Button Content="Browse..." Width="80" Command="{Binding BrowseYtDlp}"/>
                <TextBlock Text="{Binding YtDlpStatus}" VerticalAlignment="Center" Margin="10,0,0,0" FontWeight="SemiBold"/>
            </StackPanel>

            <!-- ffmpeg -->
            <StackPanel Orientation="Horizontal" Margin="0,5">
                <TextBlock Text="ffmpeg Path:" VerticalAlignment="Center" Width="110"/>
                <TextBox Text="{Binding Settings.FfmpegPath, UpdateSourceTrigger=PropertyChanged}" Width="320" Margin="0,0,10,0"/>
                <Button Content="Browse..." Width="80" Command="{Binding BrowseFfmpeg}"/>
                <TextBlock Text="{Binding FfmpegStatus}" VerticalAlignment="Center" Margin="10,0,0,0" FontWeight="SemiBold"/>
            </StackPanel>

            <!-- deno (yt-dlp JS runtime) -->
            <StackPanel Orientation="Horizontal" Margin="0,5">
                <TextBlock Text="deno Path:" VerticalAlignment="Center" Width="110"/>
                <TextBox Text="{Binding Settings.DenoPath, UpdateSourceTrigger=PropertyChanged}" Width="320" Margin="0,0,10,0"/>
                <Button Content="Browse..." Width="80" Command="{Binding BrowseDeno}"/>
                <TextBlock Text="{Binding DenoStatus}" VerticalAlignment="Center" Margin="10,0,0,0" FontWeight="SemiBold"/>
            </StackPanel>
            <TextBlock Text="deno is yt-dlp's JS runtime — YouTube now needs it to decode video streams. Without it, search and downloads may return nothing."
                       FontSize="11" Foreground="Gray" TextWrapping="Wrap" Margin="110,2,0,0"/>

            <Separator Margin="0,16"/>

            <TextBlock Text="Playback Quality" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
            <CheckBox Content="Prefer HD playback (recommended)"
                      IsChecked="{Binding Settings.ForceHdPlayback}"/>
            <TextBlock Text="Asks YouTube for the best quality your screen can use instead of its (often low) automatic pick. Falls back to automatic quality if the connection can't keep up or YouTube declines. Note: the source upload still matters — some channels upload choppy or low-bitrate videos, while others (e.g. official publisher channels) look excellent at the same resolution."
                       FontSize="11" Foreground="Gray" TextWrapping="Wrap" Margin="24,2,0,0"/>

            <Separator Margin="0,16"/>

            <TextBlock Text="Player" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
            <StackPanel Orientation="Horizontal" Margin="0,5">
                <TextBlock Text="Controls bar:" VerticalAlignment="Center" Width="110"/>
                <ComboBox Width="160" SelectedItem="{Binding SelectedBarStyle}"
                          ItemsSource="{Binding Source={StaticResource PlayerBarStyleValues}}"/>
            </StackPanel>
            <TextBlock Text="Frosted-glass looks for the player's controls bar. Preview below updates as you pick. Performance = a plain strip below the video (no glass) — pick it if you ever see stutter."
                       FontSize="11" Foreground="Gray" TextWrapping="Wrap" Margin="110,2,0,8"/>

            <!-- Live preview of the selected glass style (real backdrop-filter render). -->
            <Border Margin="110,4,0,0" Width="420" HorizontalAlignment="Left"
                    BorderBrush="#3C3C3C" BorderThickness="1" CornerRadius="4" SnapsToDevicePixels="True">
                <Image Source="{Binding BarStylePreviewPath}" Width="420" Height="160" Stretch="Fill"/>
            </Border>

            <CheckBox Content="Auto-hide the bottom bar when the player is fullscreen"
                      IsChecked="{Binding Settings.FullscreenBarAutoHide}" Margin="0,12,0,0"/>
            <TextBlock Text="Unchecked: the controls bar stays visible in fullscreen. RB / P toggles it during playback either way."
                       FontSize="11" Foreground="Gray" TextWrapping="Wrap" Margin="24,2,0,0"/>

            <Separator Margin="0,16"/>

            <TextBlock Text="Search" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
            <StackPanel Orientation="Horizontal" Margin="0,5">
                <TextBlock Text="Results to show:" VerticalAlignment="Center" Width="110"/>
                <TextBox Text="{Binding Settings.SearchResultCount}" Width="60"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,5">
                <TextBlock Text="Query template:" VerticalAlignment="Center" Width="110"/>
                <TextBox Text="{Binding Settings.QueryTemplate}" Width="320"/>
            </StackPanel>
            <TextBlock Text="Use {name} as the game-name placeholder." FontSize="11" Foreground="Gray" Margin="110,0,0,0"/>

            <Separator Margin="0,16"/>

            <TextBlock Text="Download" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
            <StackPanel Orientation="Horizontal" Margin="0,5">
                <TextBlock Text="Quality:" VerticalAlignment="Center" Width="110"/>
                <ComboBox Width="140" SelectedItem="{Binding Settings.DownloadQuality}"
                          ItemsSource="{Binding Source={StaticResource VideoQualityValues}}"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,5">
                <TextBlock Text="Cookies source:" VerticalAlignment="Center" Width="110"/>
                <ComboBox Width="140" SelectedItem="{Binding Settings.CookiesSource}"
                          ItemsSource="{Binding Source={StaticResource CookieModeValues}}"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,5">
                <TextBlock Text="Custom cookies file:" VerticalAlignment="Center" Width="110"/>
                <TextBox Text="{Binding Settings.CustomCookiesFilePath, UpdateSourceTrigger=PropertyChanged}" Width="320" Margin="0,0,10,0"/>
                <Button Content="Browse..." Width="80" Command="{Binding BrowseCookiesFile}"/>
            </StackPanel>
            <CheckBox Content="Pause UniPlaySong while a trailer plays"
                      IsChecked="{Binding Settings.PauseUniPlaySong}" Margin="0,10,0,0"/>

            <Separator Margin="0,16"/>

            <StackPanel Orientation="Horizontal">
                <CheckBox Content="Enable debug logging (FullReel.log)"
                          IsChecked="{Binding Settings.EnableDebugLogging}" VerticalAlignment="Center"/>
                <Button Content="Open Log Folder" Width="120" Margin="16,0,0,0"
                        Command="{Binding OpenLogFolder}"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
